# ─── Server-only ──────────────────────────────────────────────────────────────
# Postgres de Supabase. Usamos los mismos nombres que inyecta la integración
# Supabase ↔ Vercel, así que en Vercel no hace falta setear nada:
#
#   POSTGRES_URL              → runtime de la app (pooler, port 6543)
#   POSTGRES_URL_NON_POOLING  → migraciones / DDL (directa, port 5432)
#
# Para correr local copiar ambos strings desde Supabase (Project Settings →
# Database → Connection string). POSTGRES_URL_NON_POOLING solo es necesaria
# si vas a correr `pnpm db:*` desde local.
POSTGRES_URL="postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require&supa=base-pooler.x"
POSTGRES_URL_NON_POOLING="postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require&supa=base-pooler.x"

# Bypass de RLS para flujos admin (opcional).
# Vercel + integración Supabase la inyecta como SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SERVICE_ROLE_KEY=""

# Bearer del endpoint /api/cron/expire (≥32 chars). OPCIONAL.
# Si no se setea, el endpoint queda deshabilitado. Generar con:
#   openssl rand -base64 32
CRON_SECRET=""

# ─── Public (inlineadas en bundle del browser) ────────────────────────────────
# La integración Supabase en Vercel inyecta NEXT_PUBLIC_SUPABASE_URL y
# NEXT_PUBLIC_SUPABASE_ANON_KEY automáticamente.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Nota: los orígenes permitidos para embeber el iframe se configuran por
# formulario desde el dashboard (form detail → Integration → "Origins parent
# permitidos"), no via env vars.
